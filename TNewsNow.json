    {
      "parameters": {
        "jsCode": "const inputDate = new Date( $input.first().json.currentDate); // replace with your actual field name\n\n// Convert to IST (UTC+5:30) regardless of server timezone\nconst istOffset = 5.5 * 60 * 60 * 1000;\nconst utcTime = inputDate.getTime() + (inputDate.getTimezoneOffset() * 60 * 1000);\nconst istTime = new Date(utcTime + istOffset);\n\n// Round to nearest 5 minutes\nlet minutes = istTime.getMinutes();\nlet roundedMinutes = Math.round(minutes / 5) * 5;\nif (roundedMinutes === 60) {\n  istTime.setHours(istTime.getHours() + 1);\n  roundedMinutes = 0;\n}\nistTime.setMinutes(roundedMinutes);\n\n// Format date: \"July 19, 2026\"\nconst dateStr = istTime.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });\n\n// Format time: 12-hour with AM/PM\nlet hours = istTime.getHours();\nconst ampm = hours >= 12 ? 'PM' : 'AM';\nhours = hours % 12;\nhours = hours === 0 ? 12 : hours;\nconst minStr = roundedMinutes.toString().padStart(2, '0');\nconst timeStr = `${hours}:${minStr} ${ampm}`;\n\nconst finalMessage = `The news updates for ${dateStr} at ${timeStr}`;\n\nreturn [{ json: { message: finalMessage } }];"
      },
