    {
      "parameters": {
        "jsCode": "const article = $input.first().json;\n\nconst text = article.text || \"\";\nconst image = article.ogImage || \"\";\nconst description = article.ogDescription || \"\";\n\nconst html = `\n<!DOCTYPE html>\n<html lang=\"ta\">\n<head>\n<meta charset=\"UTF-8\">\n\n<link href=\"https://fonts.googleapis.com/css2?family=Noto+Sans+Tamil:wght@400;700;800&display=swap\" rel=\"stylesheet\">\n\n<style>\n\n*{\n    box-sizing:border-box;\n}\n\nbody{\n    margin:0;\n    width:1080px;\n    height:1350px;\n    overflow:hidden;\n    font-family:'Noto Sans Tamil',sans-serif;\n\n    background:\n        linear-gradient(rgba(0,0,0,.65),rgba(0,0,0,.65)),\n        url('${image}') center center / cover no-repeat;\n\n    display:flex;\n    justify-content:center;\n    align-items:center;\n}\n\n.card{\n    width:900px;\n    background:#fff;\n    border-radius:35px;\n    overflow:hidden;\n    box-shadow:0 20px 70px rgba(0,0,0,.45);\n}\n\n.image{\n    width:100%;\n    height:500px;\n    object-fit:cover;\n}\n\n.badge{\n    display:inline-block;\n    margin:25px;\n    padding:12px 24px;\n    background:#ff3b30;\n    color:#fff;\n    font-size:24px;\n    font-weight:bold;\n    border-radius:999px;\n}\n\n.title{\n    padding:0 30px;\n    font-size:44px;\n    font-weight:800;\n    line-height:1.3;\n    color:#111827;\n}\n\n.summary{\n    padding:30px;\n    font-size:28px;\n    line-height:1.6;\n    color:#444;\n}\n\n.footer{\n    background:#111827;\n    color:white;\n    padding:20px;\n    text-align:center;\n    font-size:22px;\n}\n\n</style>\n\n</head>\n\n<body>\n\n<div class=\"card\">\n\n<img class=\"image\" src=\"${image}\" />\n\n<div class=\"badge\">📰 BREAKING NEWS</div>\n\n<div class=\"title\">\n${description}\n</div>\n\n<div class=\"summary\">\n${text.substring(0,700)}...\n</div>\n\n<div class=\"footer\">\n*footer-brand-name*\n</div>\n\n</div>\n\n</body>\n</html>\n`;\n\nreturn [\n  {\n    json: {\n      html\n    }\n  }\n];"
      },
