    {
      "parameters": {
        "jsCode": "const headlines = $input.first().json.headline;\nconst links = $input.first().json.articleLinks;\n\nconst seen = new Set();\nconst result = [];\n\nfor (let i = 0; i < links.length; i++) {\n  const url = links[i];\n  if (!seen.has(url)) {\n    seen.add(url);\n    result.push({\n      json: {\n        title: Array.isArray(headlines) ? headlines[i] : null,\n        url: url\n      }\n    });\n  }\n}\n\nreturn result;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        96,
        -112
      ],
      "id": "d27d07bf-93f0-4e62-8a17-439feba441e8",
      "name": "Format Content"
    },
    {
      "parameters": {
        "jsCode": "const item = $input.first().json;\nconst paragraphs = $input.first().json.bodyText;\nlet text = Array.isArray(paragraphs) ? paragraphs.join(' ') : paragraphs;\n\n// Strip URLs (plain and bracketed [https://...] formats)\ntext = text.replace(/\\[?(https?:\\/\\/[^\\s\\]\\n]+)\\]?/g, '');\n\n// Clean up leftover extra spaces/newlines from the removal\ntext = text.replace(/[ \\t]{2,}/g, ' ').replace(/\\n{2,}/g, '\\n').trim();\n\nreturn [{\n  json: {\n    text: text,\n    ogImage: item.ogImage,\n    ogDescription: $('Loop Over Items').first().json.title\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
